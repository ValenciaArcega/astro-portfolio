---
import "../../App.css";

const languages = [
  {
    native: "English",
    code: "en",
    hover: "hover:bg-sky-50 hover:text-sky-600 hover:border-sky-200",
  },
  {
    native: "العربية",
    code: "ar",
    hover:
      "hover:bg-emerald-50 hover:text-emerald-600 hover:border-emerald-200",
  },
  {
    native: "Deutsch",
    code: "de",
    hover: "hover:bg-blue-50 hover:text-blue-600 hover:border-blue-200",
  },
  {
    native: "中文",
    code: "zh",
    hover: "hover:bg-rose-50 hover:text-rose-600 hover:border-rose-200",
  },
  {
    native: "日本語",
    code: "jp",
    hover: "hover:bg-amber-50 hover:text-amber-600 hover:border-amber-200",
  },
  {
    native: "Русский",
    code: "ru",
    hover: "hover:bg-violet-50 hover:text-violet-600 hover:border-violet-200",
  },
  {
    native: "Español",
    code: "es",
    hover: "hover:bg-orange-50 hover:text-orange-600 hover:border-orange-200",
  },
  {
    native: "Português",
    code: "pt",
    hover: "hover:bg-green-50 hover:text-green-600 hover:border-green-200",
  },
  {
    native: "Italiano",
    code: "it",
    hover: "hover:bg-cyan-50 hover:text-cyan-600 hover:border-cyan-200",
  },
  {
    native: "Français",
    code: "fr",
    hover: "hover:bg-indigo-50 hover:text-indigo-600 hover:border-indigo-200",
  },
  {
    native: "한국어",
    code: "ko",
    hover: "hover:bg-pink-50 hover:text-pink-600 hover:border-pink-200",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Flexmate — Fitness Comrade</title>
    <link rel="icon" type="image/png" href="/flexmate.png" />
    <meta
      name="description"
      content="Flexmate helps you log workouts, track records, and break barriers — in your language."
    />
    <style>
      @keyframes fade-up {
        0% {
          opacity: 0;
          transform: translateY(24px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-fade-up {
        animation: fade-up 0.8s ease-out forwards;
      }
      .animate-fade-up-delay-1 {
        animation: fade-up 0.8s ease-out 0.15s forwards;
        opacity: 0;
      }
      .animate-fade-up-delay-2 {
        animation: fade-up 0.8s ease-out 0.3s forwards;
        opacity: 0;
      }
      .animate-fade-up-delay-3 {
        animation: fade-up 0.8s ease-out 0.45s forwards;
        opacity: 0;
      }
      .reveal {
        opacity: 0;
        transform: translateY(50px) scale(0.92);
        filter: blur(6px);
        transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
      .lang-grid:has(button:hover) button:not(:hover) {
        filter: blur(1px);
        opacity: 0.55;
        transform: scale(0.95);
      }
      .lang-grid:has(button:hover) button:hover {
        transform: scale(1.04);
      }
      .letter-in {
        display: inline-block;
        opacity: 0;
        filter: blur(12px);
        animation: letterFadeIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      @keyframes letterFadeIn {
        from {
          opacity: 0;
          filter: blur(12px);
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          filter: blur(0);
          transform: translateY(0);
        }
      }
      .logo-pulse {
        animation: logoPulse 4s ease-in-out infinite;
      }
      @keyframes logoPulse {
        0%,
        100% {
          transform: scale(1);
          opacity: 1;
        }
        50% {
          transform: scale(1.06);
          opacity: 0.85;
        }
      }
      .scroll-hide::-webkit-scrollbar {
        display: none;
      }
      .scroll-hide {
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      .mask-edges {
        mask-image: linear-gradient(
          to right,
          transparent 0%,
          black 6%,
          black 94%,
          transparent 100%
        );
        -webkit-mask-image: linear-gradient(
          to right,
          transparent 0%,
          black 6%,
          black 94%,
          transparent 100%
        );
      }
      .float-bubble {
        animation: floatUp 3s ease-in-out infinite;
      }
      .float-bubble:nth-child(2) {
        animation-delay: 0.8s;
      }
      .float-bubble:nth-child(3) {
        animation-delay: 1.6s;
      }
      @keyframes floatUp {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-6px);
        }
      }
      .img-enter {
        opacity: 0;
        filter: blur(6px);
        transform: translateX(-50px) scale(0.92);
      }
      .img-enter.visible {
        animation: imgEnter 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      @keyframes imgEnter {
        to {
          opacity: 1;
          filter: blur(0);
          transform: translateX(0) scale(1);
        }
      }
      .image-stack img {
        transition:
          margin-left 0.5s ease-out,
          transform 0.5s ease-out;
      }
      .image-stack:has(:hover) img:nth-child(n + 2) {
        margin-left: -17% !important;
      }
      .image-stack:has(:hover) img:nth-child(1) {
        transform: rotate(-6deg);
      }
      .image-stack:has(:hover) img:nth-child(2) {
        transform: rotate(-3deg);
      }
      .image-stack:has(:hover) img:nth-child(3) {
        transform: rotate(0deg);
      }
      .image-stack:has(:hover) img:nth-child(4) {
        transform: rotate(3deg);
      }
      .image-stack:has(:hover) img:nth-child(5) {
        transform: rotate(6deg);
      }
      .hero-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        pointer-events: none;
      }
      .hero-orb--blue {
        width: 500px;
        height: 500px;
        background: rgba(59, 130, 246, 0.08);
        top: -10%;
        left: -10%;
        animation: orbFloat 12s ease-in-out infinite;
      }
      .hero-orb--orange {
        width: 400px;
        height: 400px;
        background: rgba(251, 146, 60, 0.15);
        bottom: 8%;
        right: 8%;
        animation: orbFloat 15s ease-in-out infinite reverse;
      }
      .hero-orb--small {
        width: 250px;
        height: 250px;
        background: rgba(99, 102, 241, 0.1);
        top: 50%;
        left: 50%;
        animation: orbFloat 10s ease-in-out infinite 2s;
      }
      @keyframes orbFloat {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        33% {
          transform: translate(40px, -30px) scale(1.05);
        }
        66% {
          transform: translate(-20px, 20px) scale(0.95);
        }
      }
    </style>
  </head>
  <body class="m-0 bg-white text-gray-900 antialiased">
    <main>
      <section
        class="relative min-h-dvh flex flex-col items-center justify-center overflow-hidden bg-white"
      >
        <div class="hero-orb hero-orb--blue"></div>
        <div class="hero-orb hero-orb--orange"></div>
        <div class="hero-orb hero-orb--small"></div>
        <header class="relative z-10 text-center px-6 max-w-3xl mx-auto">
          <div class="mx-auto w-44 h-44 animate-fade-up logo-pulse">
            <img
              src="/flexmate.png"
              alt="Flexmate"
              class="w-full h-full object-contain"
            />
          </div>
          <h1
            class="text-6xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight text-gray-900"
          >
            {
              "Flexmate".split("").map((char, i) => (
                <span class="letter-in" style={`animation-delay: ${i * 0.09}s`}>
                  {char === " " ? " " : char}
                </span>
              ))
            }
          </h1>
          <p
            class="text-lg sm:text-xl text-gray-500 mt-4 max-w-md mx-auto animate-fade-up-delay-2"
          >
            Track every rep. Own every day.
          </p>
        </header>

        <nav
          class="relative z-10 mt-12 flex flex-wrap items-center justify-center gap-4 px-6 animate-fade-up-delay-3"
        >
          <a
            href="#"
            class="inline-flex items-center gap-3 px-8 py-4 border-2 border-gray-200 text-gray-900 rounded-full font-medium text-sm sm:text-base hover:border-blue-300 hover:text-blue-600 transition-all duration-500 shadow-lg shadow-gray-900/5 hover:shadow-blue-100/40 hover:-translate-y-0.5"
          >
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-6 h-6 shrink-0"
            >
              <path
                d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"
              ></path>
            </svg>
            App Store
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-3 px-8 py-4 border-2 border-gray-200 text-gray-900 rounded-full font-medium text-sm sm:text-base hover:border-orange-300 hover:text-orange-600 transition-all duration-500 shadow-lg shadow-gray-900/5 hover:shadow-orange-200/40 hover:-translate-y-0.5"
          >
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 shrink-0"
            >
              <path
                d="M3.609 2.516a.75.75 0 0 0-.375.65v17.668a.75.75 0 0 0 .375.65.74.74 0 0 0 .744-.014l15.16-8.834a.75.75 0 0 0 0-1.272L4.353 2.53a.74.74 0 0 0-.744-.014z"
              ></path>
            </svg>
            Google Play
          </a>
        </nav>
      </section>

      <section class="pb-28 pt44 sm:py-36 px-6 bg-white">
        <header class="text-center max-w-2xl mx-auto mb-10 reveal">
          <span
            class="inline-block text-xs font-bold tracking-widest text-blue-500 uppercase bg-blue-50 px-4 py-2 rounded-full mb-5"
            >Features</span
          >
          <h2
            class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-gray-900"
          >
            Built for every workout
          </h2>
          <p class="text-gray-500 mt-4 text-lg">
            Log your routines, track your records, and see your progress grow
            over time.
          </p>
        </header>

        <div class="max-w-5xl mx-auto">
          <div
            class="relative flex flex-row justify-center overflow-visible px-6 md:px-8 image-stack"
          >
            <img
              src="/flexmate/record.png"
              alt=""
              class="w-[40%] shrink-0 relative z-40 img-enter"
              style="animation-delay: 0s"
              loading="lazy"
            />
            <img
              src="/flexmate/sets.png"
              alt=""
              class="w-[40%] shrink-0 -ml-[22%] relative z-30 img-enter"
              style="animation-delay: 0.15s"
              loading="lazy"
            />
            <img
              src="/flexmate/tracking.png"
              alt=""
              class="w-[40%] shrink-0 -ml-[22%] relative z-20 img-enter"
              style="animation-delay: 0.3s"
              loading="lazy"
            />
            <img
              src="/flexmate/workout.png"
              alt=""
              class="w-[40%] shrink-0 -ml-[22%] relative z-10 img-enter"
              style="animation-delay: 0.45s"
              loading="lazy"
            />
            <img
              src="/flexmate/add-workout.png"
              alt=""
              class="w-[40%] shrink-0 -ml-[22%] relative z-0 img-enter"
              style="animation-delay: 0.6s"
              loading="lazy"
            />
          </div>
        </div>
      </section>

      <section class="py-28 sm:py-36 px-6 bg-white overflow-hidden">
        <div class="max-w-5xl mx-auto">
          <header class="text-center max-w-3xl mx-auto mb-6 reveal">
            <span
              class="inline-block text-xs font-bold tracking-widest text-orange-500 uppercase bg-orange-50 px-4 py-2 rounded-full mb-5"
              >No frontiers</span
            >
            <h2
              class="text-4xl sm:text-4xl md:text-5xl font-bold tracking-tight text-gray-900"
            >
              Your Language. No Limits.
            </h2>
            <p class="text-gray-500 mt-4 text-lg">
              Flexmate speaks the languages ​​of the world. Because language
              should never be a barrier. More ​​coming soon...
            </p>
          </header>

          <div
            class="flex flex-wrap justify-center gap-3 max-w-2xl mx-auto mb-16 lang-grid"
            id="language-list"
          >
            {
              languages.map((lang, i) => (
                <button
                  data-index={i}
                  class={`px-5 py-2.5 bg-white rounded-full text-sm font-medium text-gray-700 shadow-sm border border-gray-100 transition-all duration-500 ${lang.hover} hover:scale-110`}
                >
                  {lang.native}
                </button>
              ))
            }
          </div>

          <div class="overflow-x-auto scroll-hide pb-4 -mx-6 px-6 mask-edges">
            <div class="flex gap-5 justify-center min-w-max">
              {
                languages.map((lang) => {
                  const iosCodes = ["en", "ar", "es", "jp", "ru", "zh"];
                  if (!iosCodes.includes(lang.code)) return null;
                  const imgPath = `/flexmate/multi-lang/ios-week-${lang.code}.png`;
                  return (
                    <figure class="flex flex-col items-center gap-2 shrink-0">
                      <div class="w-35 h-72.5 rounded-[1.25rem] overflow-hidden bg-white shadow-lg shadow-gray-200/60">
                        <img
                          src={imgPath}
                          alt={`Flexmate in ${lang.native}`}
                          class="w-full h-full object-cover"
                          loading="lazy"
                        />
                      </div>
                      <figcaption class="text-xs font-medium text-gray-400">
                        {lang.native}
                      </figcaption>
                    </figure>
                  );
                })
              }
            </div>
          </div>
        </div>
      </section>

      <footer class="relative bg-white">
        <div
          class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-gray-200 to-transparent"
        >
        </div>

        <div class="max-w-6xl mx-auto px-6 py-14 sm:py-16">
          <div
            class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6"
          >
            <header class="items-center gap-4">
              <div class="w-16 h-16 shrink-0">
                <img
                  src="/flexmate.png"
                  alt="Flexmate"
                  class="w-full h-full object-contain"
                />
              </div>
              <p
                class="text-lg sm:text-xl font-bold text-gray-900 leading-snug max-w-sm"
              >
                Download it now!
              </p>
              <p class="text-xs sm:text-sm text-gray-400 leading-snug max-w-sm">
                Crafted with love by <a
                  class="underline"
                  href="https://www.linkedin.com/in/luis-angel-valencia-arcega-4827b9239"
                  target="_blank">Angel Valencia Arcega.</a
                >
              </p>
            </header>

            <nav class="flex flex-wrap gap-3">
              <a
                href="#"
                class="inline-flex items-center gap-2.5 px-6 py-3 border-2 border-gray-200 text-gray-900 rounded-full font-medium text-sm hover:border-blue-300 hover:text-blue-600 transition-all duration-500 shadow-lg shadow-gray-900/5 hover:shadow-blue-100/40 hover:-translate-y-0.5"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="w-5 h-5 shrink-0"
                >
                  <path
                    d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"
                  ></path>
                </svg>
                App Store
              </a>
              <a
                href="#"
                class="inline-flex items-center gap-2.5 px-6 py-3 border-2 border-gray-200 text-gray-900 rounded-full font-medium text-sm hover:border-orange-300 hover:text-orange-600 transition-all duration-500 shadow-lg shadow-gray-900/5 hover:shadow-orange-200/40 hover:-translate-y-0.5"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="w-4 h-4 shrink-0"
                >
                  <path
                    d="M3.609 2.516a.75.75 0 0 0-.375.65v17.668a.75.75 0 0 0 .375.65.74.74 0 0 0 .744-.014l15.16-8.834a.75.75 0 0 0 0-1.272L4.353 2.53a.74.74 0 0 0-.744-.014z"
                  ></path>
                </svg>
                Google Play
              </a>
            </nav>
          </div>

          <div
            class="mt-10 pt-6 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-400"
          >
            <p>
              &copy; {new Date().getFullYear()} Flexmate. All rights reserved.
            </p>
            <nav class="flex items-center gap-5">
              <a
                href="/flexmate/privacy"
                target="_blank"
                class="hover:text-gray-600 hover:underline transition-colors duration-300"
                >Privacy Policy</a
              >
            </nav>
          </div>
        </div>
      </footer>
    </main>

    <script>
      const reveals = document.querySelectorAll(".reveal, .img-enter");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );
      reveals.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
