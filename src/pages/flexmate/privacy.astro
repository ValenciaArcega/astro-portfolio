---
import "../../App.css";

const lastUpdated = "July 9, 2026";
const appName = "Flexmate";
const contactEmail = "dev.valenciaarcega@gmail.com";

const privacyPoints = [
  {
    number: "01",
    title: "Your training data stays on your device",
    description:
      "The app is designed to work primarily offline. Your routines, records, statistics, and progress are stored locally on your device to provide a fast, private experience available at any time. You may manually trigger a sync to back up your data to our servers whenever you choose.",
  },
  {
    number: "02",
    title: "Adults-only application",
    description:
      "Flexmate is intended for use by adults only, consistent with the age rating assigned to the App in the App Store and Google Play. The App does not knowingly collect information from individuals under the age of majority in their country of residence. By creating an account, you confirm that you are an adult under applicable law.",
  },
  {
    number: "03",
    title: "Information required to create an account",
    description:
      "When you create an account, only your full name, email address, and password are stored. Your email is used exclusively to log in and recover access to your account when needed. Your password is stored securely and cannot be viewed by the app's administrators. Additionally, uploading a profile photo is optional and is not required during registration — if you choose to add one from the Edit Profile screen, it is stored in our database and used solely to display alongside your name within the App.",
  },
  {
    number: "04",
    title: "Delete your account",
    description:
      "Flexmate allows you to permanently delete your account and associated data directly from the App. You may delete your account at any time from Settings within the App (Account > Delete Account). Deleting your account permanently removes your profile information, saved routines, activity logs, and profile photo from both our servers and the device on which you requested the deletion.",
  },
  {
    number: "05",
    title: "Manual backup to protect your data",
    description:
      "To prevent data loss when switching devices or reinstalling the app, you can manually sync your training data and statistics to our servers at any time from within the App. No automatic or periodic backups are performed — syncing only occurs when you choose to trigger it.",
  },
  {
    number: "06",
    title: "Transparency about data storage",
    description:
      "Backed-up data is not stored with content-level encryption. The stored data may be accessible for system administration and maintenance tasks, as with any online storage system, we recommend avoiding storing sensitive personal information within the app beyond what is necessary for its core functionality.",
  },
  {
    number: "07",
    title: "Your information is not shared or sold",
    description:
      "The information stored in the app and in backups is not sold, rented, or shared with third parties for commercial purposes. Its sole purpose is to provide the app's functionality.",
  },
  {
    number: "08",
    title: "Not medical advice",
    description:
      "Consult a healthcare professional before starting any exercise routine. This App is not a substitute for professional advice. Before starting any exercise program, you should consult a physician or qualified health professional, especially if you have a pre-existing medical condition, injury, or are unsure about your physical ability to perform certain exercises. \nYou are solely responsible for evaluating your own physical condition and for any decision to start, continue, or stop a workout routine. Flexmate does not assume responsibility for injuries, health complications, or damages resulting from the use of information, routines, or records stored in the App.",
  },
  {
    number: "09",
    title: "Acceptable use",
    description:
      "You agree not to: \n(a) attempt to gain unauthorized access to the App's systems or other users' accounts;\n(b) reverse-engineer or decompile the App beyond what is permitted by applicable law; \n(c) use the App for any purpose that violates applicable laws or regulations.",
  },
  {
    number: "10",
    title: "Changes to this policy",
    description:
      "We may update this Privacy Policy from time to time to reflect changes in our practices or for legal, regulatory, or operational reasons. Material changes will be communicated within the App or through other reasonable means. We encourage you to review this page periodically to stay informed about how we protect your information.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/flexmate.png" />
    <title>{appName} — Privacy Policy</title>
    <style>
      @keyframes fancy-fade {
        0% {
          opacity: 0;
          transform: translateY(50px) scale(0.92);
          filter: blur(6px);
        }
        100% {
          opacity: 1;
          transform: translateY(0) scale(1);
          filter: blur(0);
        }
      }
      .reveal {
        opacity: 0;
        transform: translateY(50px) scale(0.92);
        filter: blur(6px);
        transition: all 0.9s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
    </style>
  </head>

  <body>
    <main
      class="relative min-h-screen overflow-hidden bg-zinc-950 text-zinc-100"
    >
      <div
        class="pointer-events-none absolute left-1/2 top-0 h-90 w-90 -translate-x-1/2 rounded-full bg-blue-500/10 blur-[90px] sm:h-130 sm:w-130 sm:blur-[120px]"
      >
      </div>

      <div
        class="pointer-events-none absolute -right-32 top-72 h-80 w-[320px] rounded-full bg-violet-500/10 blur-[100px] sm:h-105 sm:w-105"
      >
      </div>

      <section
        class="relative mx-auto max-w-5xl px-5 py-12 sm:px-6 sm:py-20 lg:py-24"
      >
        <div
          class="mb-8 inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-zinc-900/70 px-4 py-2 text-xs text-zinc-400 shadow-2xl shadow-black/20 backdrop-blur sm:mb-10 sm:text-sm"
        >
          <span
            class="h-2 w-2 rounded-full bg-blue-400 shadow-[0_0_16px_rgba(96,165,250,0.9)]"
          ></span>
          {appName} Privacy
        </div>

        <header class="mb-14 reveal">
          <h1
            class="relative inline-block text-5xl font-bold tracking-tight text-white sm:text-6xl"
          >
            Privacy Policy

            <svg
              class="absolute -bottom-4 left-0 w-full sm:-bottom-10 md:-bottom-6 lg:-bottom-4"
              viewBox="0 0 320 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              preserveAspectRatio="none"
            >
              <defs>
                <linearGradient
                  id="title-gradient"
                  x1="0%"
                  y1="0%"
                  x2="100%"
                  y2="0%"
                >
                  <stop offset="0%" stop-color="#3B82F6"></stop>
                  <stop offset="50%" stop-color="#60A5FA"></stop>
                  <stop offset="100%" stop-color="#a855f7"></stop>
                </linearGradient>
              </defs>

              <path
                d="M4 18C40 10 80 6 120 10C170 15 220 24 316 8"
                stroke="url(#title-gradient)"
                stroke-width="7"
                stroke-linecap="round"
                class="drop-shadow-[0_0_12px_rgba(59,130,246,0.35)]"></path>
            </svg>
          </h1>

          <p class="mt-5 max-w-2xl text-lg leading-8 text-zinc-400">
            Learn clearly and transparently how information associated with the
            use of
            <span class="text-zinc-200">{appName}</span> is stored, used, and protected.
          </p>

          <p class="mt-6 text-sm text-zinc-500">
            Last updated:
            <span class="text-zinc-300">{lastUpdated}</span>
          </p>
        </header>

        <section class="grid gap-5 reveal">
          {
            privacyPoints.map((point) => (
              <article class="group relative overflow-hidden rounded-[28px] border-2 border-white/10 bg-white/3 p-5 shadow-2xl shadow-black/20 backdrop-blur transition duration-700 hover:border-blue-400/30 hover:bg-white/5 sm:rounded-4xl sm:p-8">
                <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-blue-400/50 to-transparent opacity-0 transition duration-300 group-hover:opacity-100" />

                <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-5">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-blue-400/20 bg-blue-400/10 text-sm font-bold text-blue-300 shadow-lg shadow-blue-500/10 sm:h-14 sm:w-14">
                    {point.number}
                  </div>

                  <div>
                    <h2 class="text-lg font-semibold tracking-tight text-white sm:text-2xl">
                      {point.title}
                    </h2>

                    <p
                      style="white-space: pre-wrap"
                      class="mt-3 max-w-3xl text-sm leading-7 text-zinc-400 sm:text-base sm:leading-8"
                    >
                      {point.description}
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </section>

        <section
          class="mt-8 rounded-[28px] border border-amber-400/20 bg-amber-400/6 p-5 shadow-2xl shadow-black/20 sm:rounded-4xl sm:p-8 reveal"
        >
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
            <div
              class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-amber-300/20 bg-amber-300/10 text-amber-200"
            >
              ✦
            </div>

            <div>
              <h2
                class="text-lg font-semibold tracking-tight text-white sm:text-xl"
              >
                Important note
              </h2>

              <p
                class="mt-3 max-w-3xl text-sm leading-7 text-zinc-300 sm:text-base sm:leading-8"
              >
                While we implement reasonable measures to protect stored
                information, no computer system can guarantee absolute security.
              </p>
            </div>
          </div>
        </section>

        <footer
          class="mt-12 border-t border-white/10 pt-8 text-sm leading-7 text-zinc-500 sm:mt-14"
        >
          <p>
            For any questions regarding this privacy policy, please contact
            <a
              href={`mailto:${contactEmail}`}
              class="text-blue-400 underline underline-offset-4 transition hover:text-blue-300"
            >
              {contactEmail}
            </a>.
          </p>

          <p class="mt-4">
            © {new Date().getFullYear()}
            {appName}. All rights reserved.
          </p>
        </footer>
      </section>
    </main>

    <script>
      const reveals = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );
      reveals.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
