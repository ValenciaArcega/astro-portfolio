---
import {
	PiAndroidLogoDuotone,
	PiAppleLogoDuotone,
	PiAppStoreLogoDuotone,
	PiAtomDuotone,
	PiBrainDuotone,
	PiButterflyDuotone,
	PiCodeDuotone,
	PiGooglePlayLogoDuotone,
	PiRocketDuotone,
} from "react-icons/pi";
import {
	firstProjectsSet,
	secondProjectsSet,
} from "@src/constants/slider-projects";

const twCard =
	"mb-12 mt-0 group bg-transparent duration-500 w-[94%] sm:w-96 min-h-64 py-3 flex flex-col items-center relative rounded-3xl overflow-hidden hover:shadow-xl hover:shadow-black/10 hover:-translate-y-2 border border-solid border-a910";
const twCardMain = "flex-1 z-20 flex flex-col justify-between px-6 py-4 w-full";
const twTag =
	"inline-block px-3 py-1 w-fit rounded-full text-xs font-medium border";
const twName =
	"font-semibold text-white mt-2 text-4xl customTitle tracking-wider";
const twSubtext = "text-sm text-gray-400 mt-4";
const twRow = "text-xs flex items-center gap-x-2 mt-2";
const twRowBetween = "flex justify-between w-full items-center text-white";
const twFooter = "flex justify-between mt-16";
const twLink =
	"w-[46%] text-white visited:text-purple-400 flex items-center gap-x-2 px-3 rounded-xl duration-700 underline hover:cursor-pointer";

const blobPath =
	"M39.5,-49.6C54.8,-43.2,73.2,-36.5,78.2,-24.6C83.2,-12.7,74.8,4.4,69,22.5C63.3,40.6,60.2,59.6,49.1,64.8C38.1,70,19,61.5,0.6,60.7C-17.9,59.9,-35.9,67,-47.2,61.9C-58.6,56.7,-63.4,39.5,-70,22.1C-76.6,4.7,-84.9,-12.8,-81.9,-28.1C-79,-43.3,-64.6,-56.3,-49.1,-62.5C-33.6,-68.8,-16.8,-68.3,-2.3,-65.1C12.1,-61.9,24.2,-55.9,39.5,-49.6Z";
---

<section class="pt-52">
	<section class="w-full flex flex-col" style="container-type: inline-size;">
		<header
			class="self-center w-[68%] flex flex-row relative justify-center"
		>
			<div
				class="ml-2 w-20 h-28 rounded-xl grid place-content-center border border-solid border-a900 -rotate-12 bg-transparent"
			>
				<PiRocketDuotone className="text-5xl text-gray-300" />
			</div>
			<div
				class="-ml-4 -mt-3 scale-125 z-50 w-20 max-h-24 rounded-xl grid place-content-center shadow-2xl bg-linear-to-t from-a930 to-a900 overflow-hidden border border-a700"
			>
				<PiAppStoreLogoDuotone className="text-6xl text-blue-500" />
			</div>
			<div
				class="-ml-4 w-20 h-28 rounded-xl grid place-content-center border border-solid border-a900 rotate-20 bg-transparent"
			>
				<PiCodeDuotone className="text-5xl text-gray-300 rotate-44" />
			</div>
		</header>

		<article
			class="text-[2rem] mt-6 md:text-[3rem] text-center flex flex-col items-center md:maskProjectsTitle md:dark:maskProjectsTitleDark"
		>
			<h1 class="font-medium text-white tracking-tight">
				In Production!
			</h1>
		</article>

		<article
			class="mt-8 pt-24 px-8 relative flex flex-wrap gap-4 w-full justify-around bg-linear-to-t from-[#101010] to-[#151515]"
		>
			<header
				class="absolute left-1/2 top-0 w-[80%] h-px select-none pointer-events-none -translate-x-1/2 translate-y-1/2 self-center bg-linear-to-r from-transparent via-gray-500 to-transparent"
			>
			</header>

			<!-- Flexmate -->
			<article class={twCard}>
				<svg
					viewBox="0 0 200 200"
					class="absolute blur z-10 duration-700 group-hover:blur-sm group-hover:scale-105"
					style="fill: rgba(59, 130, 246, 0.05)"
				>
					<path transform="translate(100 100)" d={blobPath}></path>
				</svg>
				<main class={twCardMain}>
					<div class="flex gap-x-2 absolute top-4 right-4">
						<PiAppleLogoDuotone
							size={25}
							className="text-gray-200"
						/>
						<PiAndroidLogoDuotone
							size={28}
							className="text-green-300"
						/>
					</div>
					<div>
						<span
							class={`${twTag} bg-blue-500/15 text-blue-400 border-blue-500/30`}
						>
							Gym app
						</span>
						<h1 class={twName}>Flexmate</h1>
						<p class={twSubtext}>The brains behind the keyboard.</p>
						<div class={twRow}>
							<PiAtomDuotone
								size={24}
								className="text-blue-500"
							/>
							<div class={twRowBetween}>
								<span>App</span>
								<p>Angel Valencia Arcega</p>
							</div>
						</div>
						<div class={twRow}>
							<PiBrainDuotone
								size={24}
								className="text-blue-500"
							/>
							<div class={twRowBetween}>
								<span>Backend</span>
								<p>Edson Reyes</p>
							</div>
						</div>
					</div>

					<footer class={twFooter}>
						<a
							target="_blank"
							href="https://apps.apple.com/us/app/flexmate/id6788123810"
							class={`${twLink} hover:text-blue-300`}
						>
							<PiAppStoreLogoDuotone size={24} />
							Download
						</a>
						<a
							target="_blank"
							href="https://apps.apple.com/us/app/flexmate/id6788123810"
							class={`${twLink} hover:text-blue-300`}
						>
							<PiGooglePlayLogoDuotone size={24} />
							Download
						</a>
					</footer>
				</main>
			</article>

			<!-- Connie -->
			<article class={twCard}>
				<svg
					viewBox="0 0 200 200"
					class="absolute blur z-10 duration-700 group-hover:blur-sm group-hover:scale-105"
					style="fill: rgba(234, 179, 8, 0.05)"
				>
					<path transform="translate(100 100)" d={blobPath}></path>
				</svg>
				<main class={twCardMain}>
					<div class="flex gap-x-2 absolute top-4 right-4">
						<PiAppleLogoDuotone
							size={25}
							className="text-gray-200"
						/>
						<PiAndroidLogoDuotone
							size={28}
							className="text-green-300"
						/>
					</div>
					<span
						class={`${twTag} bg-yellow-500/15 text-yellow-400 border-yellow-500/30`}
					>
						Chat with Artificial Intelligence
					</span>
					<h1 class={twName}>Connie</h1>
					<p class={twSubtext}>The brains behind the keyboard.</p>
					<div class={twRow}>
						<PiAtomDuotone size={24} className="text-yellow-500" />
						<div class={twRowBetween}>
							<span>App</span>
							<p>Angel Valencia Arcega</p>
						</div>
					</div>
					<div class={twRow}>
						<PiBrainDuotone size={24} className="text-yellow-500" />
						<div class={twRowBetween}>
							<span>Backend</span>
							<p>Edson Reyes & David Herrera</p>
						</div>
					</div>
					<div class="flex items-center gap-x-2 mt-8">
						<PiButterflyDuotone
							size={24}
							className="text-yellow-500"
						/>
						<p class="text-white text-xs">
							Powered by BAACC Systems
						</p>
					</div>
					<footer class={twFooter}>
						<a
							target="_blank"
							href="https://apps.apple.com/mx/app/connie-ia/id6747147819"
							class={`${twLink} hover:text-yellow-300`}
						>
							<PiAppStoreLogoDuotone size={24} />
							Download
						</a>
						<a
							target="_blank"
							href="https://play.google.com/store/apps/details?id=app.baaccsystems.connieia"
							class={`${twLink} hover:text-yellow-300`}
						>
							<PiGooglePlayLogoDuotone size={24} />
							Download
						</a>
					</footer>
				</main>
			</article>

			<!-- Flego -->
			<article class={twCard}>
				<svg
					viewBox="0 0 200 200"
					class="absolute blur z-10 duration-700 group-hover:blur-sm group-hover:scale-105"
					style="fill: rgba(20, 184, 166, 0.05)"
				>
					<path transform="translate(100 100)" d={blobPath}></path>
				</svg>
				<main class={twCardMain}>
					<div class="flex gap-x-2 absolute top-4 right-4">
						<PiAppleLogoDuotone
							size={25}
							className="text-gray-200"
						/>
						<PiAndroidLogoDuotone
							size={28}
							className="text-green-300"
						/>
					</div>
					<span
						class={`${twTag} bg-green-500/15 text-green-400 border-green-500/30`}
						>Freight transport app</span
					>
					<h1 class={twName}>Flego</h1>
					<p class={twSubtext}>The brains behind the keyboard.</p>
					<div class={twRow}>
						<PiAtomDuotone size={24} className="text-green-600" />
						<div class={twRowBetween}>
							<span>App</span>
							<p>Angel Valencia Arcega</p>
						</div>
					</div>
					<div class={twRow}>
						<PiBrainDuotone size={24} className="text-green-600" />
						<div class={twRowBetween}>
							<span>Backend</span>
							<p>Edson Reyes & Josue Cazares</p>
						</div>
					</div>
					<div class="flex items-center gap-x-2 mt-8">
						<PiButterflyDuotone
							size={24}
							className="text-green-600"
						/>
						<p class="text-white text-xs">
							Powered by TORREY DLC & BAACC Systems
						</p>
					</div>
					<footer class={twFooter}>
						<a
							target="_blank"
							href="https://apps.apple.com/mx/app/flego-tu-flete-de-regreso/id6746598808"
							class={`${twLink} hover:text-green-300`}
						>
							<PiAppStoreLogoDuotone size={24} />
							Download
						</a>
						<a
							target="_blank"
							href="https://play.google.com/store/apps/details?id=app.torreydlc.flego"
							class={`${twLink} hover:text-green-300`}
						>
							<PiGooglePlayLogoDuotone size={24} />
							Download
						</a>
					</footer>
				</main>
			</article>
		</article>
	</section>

	<header
		class="absolute left-1/2 top-0 w-[80%] h-px select-none pointer-events-none -translate-x-1/2 bg-linear-to-r from-transparent via-[#c6c6c6ab] to-transparent"
	>
	</header>
</section>

<section
	class="relative pt-32 pb-24 flex justify-center w-full items-center bg-[#101010]"
>
	<div class="h-12 w-12 bg-[#04ddff] rounded-full"></div>
	<div class="h-12 w-12 bg-[#1899ff] rounded-full"></div>

	<div
		class="absolute inset-0 flex gap-y-3 backdrop-blur-2xl flex-col items-center justify-center"
	>
		<svg
			class="spin-scale"
			viewBox="0 0 256 228"
			height={84}
			preserveAspectRatio="xMidYMid"
		>
			<path
				d="M210.483 73.824a171.49 171.49 0 0 0-8.24-2.597c.465-1.9.893-3.777 1.273-5.621 6.238-30.281 2.16-54.676-11.769-62.708-13.355-7.7-35.196.329-57.254 19.526a171.23 171.23 0 0 0-6.375 5.848 155.866 155.866 0 0 0-4.241-3.917C100.759 3.829 77.587-4.822 63.673 3.233 50.33 10.957 46.379 33.89 51.995 62.588a170.974 170.974 0 0 0 1.892 8.48c-3.28.932-6.445 1.924-9.474 2.98C17.309 83.498 0 98.307 0 113.668c0 15.865 18.582 31.778 46.812 41.427a145.52 145.52 0 0 0 6.921 2.165 167.467 167.467 0 0 0-2.01 9.138c-5.354 28.2-1.173 50.591 12.134 58.266 13.744 7.926 36.812-.22 59.273-19.855a145.567 145.567 0 0 0 5.342-4.923 168.064 168.064 0 0 0 6.92 6.314c21.758 18.722 43.246 26.282 56.54 18.586 13.731-7.949 18.194-32.003 12.4-61.268a145.016 145.016 0 0 0-1.535-6.842c1.62-.48 3.21-.974 4.76-1.488 29.348-9.723 48.443-25.443 48.443-41.52 0-15.417-17.868-30.326-45.517-39.844Zm-6.365 70.984c-1.4.463-2.836.91-4.3 1.345-3.24-10.257-7.612-21.163-12.963-32.432 5.106-11 9.31-21.767 12.459-31.957 2.619.758 5.16 1.557 7.61 2.4 23.69 8.156 38.14 20.213 38.14 29.504 0 9.896-15.606 22.743-40.946 31.14Zm-10.514 20.834c2.562 12.94 2.927 24.64 1.23 33.787-1.524 8.219-4.59 13.698-8.382 15.893-8.067 4.67-25.32-1.4-43.927-17.412a156.726 156.726 0 0 1-6.437-5.87c7.214-7.889 14.423-17.06 21.459-27.246 12.376-1.098 24.068-2.894 34.671-5.345.522 2.107.986 4.173 1.386 6.193ZM87.276 214.515c-7.882 2.783-14.16 2.863-17.955.675-8.075-4.657-11.432-22.636-6.853-46.752a156.923 156.923 0 0 1 1.869-8.499c10.486 2.32 22.093 3.988 34.498 4.994 7.084 9.967 14.501 19.128 21.976 27.15a134.668 134.668 0 0 1-4.877 4.492c-9.933 8.682-19.886 14.842-28.658 17.94ZM50.35 144.747c-12.483-4.267-22.792-9.812-29.858-15.863-6.35-5.437-9.555-10.836-9.555-15.216 0-9.322 13.897-21.212 37.076-29.293 2.813-.98 5.757-1.905 8.812-2.773 3.204 10.42 7.406 21.315 12.477 32.332-5.137 11.18-9.399 22.249-12.634 32.792a134.718 134.718 0 0 1-6.318-1.979Zm12.378-84.26c-4.811-24.587-1.616-43.134 6.425-47.789 8.564-4.958 27.502 2.111 47.463 19.835a144.318 144.318 0 0 1 3.841 3.545c-7.438 7.987-14.787 17.08-21.808 26.988-12.04 1.116-23.565 2.908-34.161 5.309a160.342 160.342 0 0 1-1.76-7.887Zm110.427 27.268a347.8 347.8 0 0 0-7.785-12.803c8.168 1.033 15.994 2.404 23.343 4.08-2.206 7.072-4.956 14.465-8.193 22.045a381.151 381.151 0 0 0-7.365-13.322Zm-45.032-43.861c5.044 5.465 10.096 11.566 15.065 18.186a322.04 322.04 0 0 0-30.257-.006c4.974-6.559 10.069-12.652 15.192-18.18ZM82.802 87.83a323.167 323.167 0 0 0-7.227 13.238c-3.184-7.553-5.909-14.98-8.134-22.152 7.304-1.634 15.093-2.97 23.209-3.984a321.524 321.524 0 0 0-7.848 12.897Zm8.081 65.352c-8.385-.936-16.291-2.203-23.593-3.793 2.26-7.3 5.045-14.885 8.298-22.6a321.187 321.187 0 0 0 7.257 13.246c2.594 4.48 5.28 8.868 8.038 13.147Zm37.542 31.03c-5.184-5.592-10.354-11.779-15.403-18.433 4.902.192 9.899.29 14.978.29 5.218 0 10.376-.117 15.453-.343-4.985 6.774-10.018 12.97-15.028 18.486Zm52.198-57.817c3.422 7.8 6.306 15.345 8.596 22.52-7.422 1.694-15.436 3.058-23.88 4.071a382.417 382.417 0 0 0 7.859-13.026 347.403 347.403 0 0 0 7.425-13.565Zm-16.898 8.101a358.557 358.557 0 0 1-12.281 19.815 329.4 329.4 0 0 1-23.444.823c-7.967 0-15.716-.248-23.178-.732a310.202 310.202 0 0 1-12.513-19.846h.001a307.41 307.41 0 0 1-10.923-20.627 310.278 310.278 0 0 1 10.89-20.637l-.001.001a307.318 307.318 0 0 1 12.413-19.761c7.613-.576 15.42-.876 23.31-.876H128c7.926 0 15.743.303 23.354.883a329.357 329.357 0 0 1 12.335 19.695 358.489 358.489 0 0 1 11.036 20.54 329.472 329.472 0 0 1-11 20.722Zm22.56-122.124c8.572 4.944 11.906 24.881 6.52 51.026-.344 1.668-.73 3.367-1.15 5.09-10.622-2.452-22.155-4.275-34.23-5.408-7.034-10.017-14.323-19.124-21.64-27.008a160.789 160.789 0 0 1 5.888-5.4c18.9-16.447 36.564-22.941 44.612-18.3ZM128 90.808c12.625 0 22.86 10.235 22.86 22.86s-10.235 22.86-22.86 22.86-22.86-10.235-22.86-22.86 10.235-22.86 22.86-22.86Z"
				fill="#00D8FF"></path>
		</svg>
		<h1 class="text-3xl text-center text-white font-medium tracking-tight">
			So much
			<span class="text-[#00D8FF]">Native</span> magic<span
				class="text-[#00D8FF]">.</span
			>
		</h1>
		<p class="text-gray-400 mt-2 px-4 text-center">
			A little taste of my work and the apps I had done.
		</p>
	</div>
</section>

<section
	class="bg-linear-to-b from-[#101010] to:black w-full text-center overflow-hidden relative"
>
	<article class="wrapperSlider">
		{
			firstProjectsSet.map((item) => (
				<img
					class="projectInSliderLeft max-h-103!"
					src={item.uri}
					alt={item.alt}
				/>
			))
		}
	</article>

	<article class="wrapperSlider">
		{
			secondProjectsSet.map((item) => (
				<img
					class="projectInSliderRight max-h-103!"
					src={item.uri}
					alt={item.alt}
				/>
			))
		}
	</article>
</section>
